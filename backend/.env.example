# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=weroi

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email — must use a verified domain in Resend (weroi.net)
