# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=weroi

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email — must use a verified domain in Resend (weroi.net)
SENDER_EMAIL=growth@weroi.net
ADMIN_EMAIL=contact.weroi@gmail.com

# Admin dashboard password (override in production — see DEPLOYMENT.md)
# Default dev fallback matches server.py if unset
ADMIN_PASSWORD=Zachattack01@

# GrowthIQ™ AI reports (optional — rule-based fallback if unset)
# Provider: auto (Groq first, then OpenAI), groq, or openai
AI_PROVIDER=auto
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# CORS — comma-separated allowed origins (include your Vercel URL)
CORS_ORIGINS=https://weroi.net,http://localhost:3000
